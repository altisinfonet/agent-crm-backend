// prisma/schema.prisma

// generator client {
//     provider = "prisma-client-js"
// }

generator client {
    provider        = "prisma-client-js"
    output          = "../generated/prisma"
    previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

/**
 * ============================================================
 * ENUMS
 * ==============================================================
 */

enum RoleName {
    OWNER
    ADMIN
    AGENT
}

enum Status {
    ACTIVE
    INACTIVE
}

enum OtpChannel {
    sms
    whatsapp
    email
}

enum OtpPurpose {
    login
    signup
    verification
}

enum SubscriptionStatus {
    active
    paused
    cancelled
}

enum PaymentStatus {
    created
    paid
    failed
}

enum SubscriptionCycle {
    WEEKLY
    MONTHLY
    YEARLY
}

enum RazorpaySubscriptionEventType {
    activated
    charged_at
    completed
    halted
    cancelled
}

/**
 * ============================================================
 * AUTH MODELS (ADDED)
 * ==============================================================
 */

model UserSession {
    id                      BigInt    @id @default(autoincrement())
    session_id              String    @unique
    user_id                 BigInt
    user                    User      @relation(fields: [user_id], references: [id])
    org_id                  BigInt?
    device_info             Json?
    ip_address              String?
    refresh_token_hash      String
    refresh_token_encrypted String?
    created_at              DateTime  @default(now())
    expires_at              DateTime
    last_used_at            DateTime?
    revoked                 Boolean   @default(false)

    @@index([session_id, user_id, org_id, ip_address, revoked])
    @@map("tbl_user_session")
}

model Otp {
    id          BigInt     @id @default(autoincrement())
    delivery_id String     @unique
    destination String
    channel     OtpChannel
    purpose     OtpPurpose
    otp_hash    String
    attempts    Int        @default(0)
    created_at  DateTime   @default(now())
    expires_at  DateTime
    used        Boolean    @default(false)
    meta        Json?

    @@index([delivery_id, destination, channel, purpose, used])
    @@map("tbl_otp")
}

/**
 * ============================================================
 * ROLE
 * ==============================================================
 */

model Role {
    id                BigInt             @id @default(autoincrement())
    name              RoleName           @unique
    description       String?
    created_at        DateTime           @default(now())
    organizationUsers OrganizationUser[]

    @@index([name])
    @@map("tbl_role")
}

/**
 * ============================================================
 * USER
 * ==============================================================
 */

model User {
    id                   BigInt               @id @default(autoincrement())
    first_name           String?
    last_name            String?
    email                String?              @unique
    phone                String?
    pan_number           String?
    kyc_status           Boolean              @default(false)
    password             String?              @db.Text()
    created_at           DateTime             @default(now())
    updated_at           DateTime             @updatedAt
    organizations        Organization[]       @relation("OrgCreatedBy")
    orgUsers             OrganizationUser[]
    customers            Customer[]           @relation("CustomerCreatedBy")
    loanDetails          ProductLoan[]
    sipDetails           ProductSip[]
    mfDetails            ProductMutualFund[]
    fdDetails            ProductFd[]
    insuranceDetails     ProductInsurance[]
    agentProductEntities AgentProductEntity[]
    sessions             UserSession[]

    @@index([first_name, last_name, email, phone, pan_number, kyc_status])
    @@map("tbl_user")
}

/**
 * ============================================================
 * ORGANIZATION
 * ==============================================================
 */

model Organization {
    id             BigInt             @id @default(autoincrement())
    name           String
    gst_number     String?
    pan_number     String?
    contact_email  String?
    contact_phone  String?
    created_by     BigInt
    createdByUser  User               @relation("OrgCreatedBy", fields: [created_by], references: [id])
    created_at     DateTime           @default(now())
    updated_at     DateTime           @updatedAt
    subscription   Subscription?
    users          OrganizationUser[]
    customers      Customer[]
    razorpayOrders RazorpayOrder[]

    @@index([name, gst_number, pan_number, contact_email, contact_phone])
    @@map("tbl_organization")
}

/**
 * ============================================================
 * ORGANIZATION USER (PIVOT)
 * ==============================================================
 */

model OrganizationUser {
    id           BigInt       @id @default(autoincrement())
    org_id       BigInt
    organization Organization @relation(fields: [org_id], references: [id])
    user_id      BigInt
    user         User         @relation(fields: [user_id], references: [id])
    role_id      BigInt
    role         Role         @relation(fields: [role_id], references: [id])
    status       Status       @default(ACTIVE)
    is_owner     Boolean      @default(false)
    created_at   DateTime     @default(now())
    updated_at   DateTime     @updatedAt

    @@unique([org_id, user_id])
    @@index([org_id, user_id, role_id, status])
    @@map("tbl_organization_user")
}

/**
 * ============================================================
 * SUBSCRIPTION PLAN
 * ==============================================================
 */

model SubscriptionPlan {
    id             BigInt            @id @default(autoincrement())
    name           String            @unique
    max_customers  Int
    price          Float
    billing_cycle  SubscriptionCycle @default(MONTHLY)
    razorpayPlanId String?           @unique
    created_at     DateTime          @default(now())
    updated_at     DateTime          @updatedAt
    subscriptions  Subscription[]

    @@index([name, billing_cycle, razorpayPlanId])
    @@map("tbl_subscription_plan")
}

/**
 * ============================================================
 * SUBSCRIPTION
 * ==============================================================
 */

model Subscription {
    id                     BigInt                      @id @default(autoincrement())
    org_id                 BigInt                      @unique
    organization           Organization                @relation(fields: [org_id], references: [id])
    plan_id                BigInt
    plan                   SubscriptionPlan            @relation(fields: [plan_id], references: [id])
    razorpaySubscriptionId String?                     @unique
    current_status         SubscriptionStatus          @default(active)
    start_date             DateTime
    end_date               DateTime
    auto_renew             Boolean                     @default(true)
    created_at             DateTime                    @default(now())
    updated_at             DateTime                    @updatedAt
    events                 RazorpaySubscriptionEvent[]

    @@index([org_id, plan_id, razorpaySubscriptionId, current_status, auto_renew])
    @@map("tbl_subscription")
}

/**
 * ============================================================
 * CUSTOMER
 * ==============================================================
 */

model Customer {
    id               BigInt              @id @default(autoincrement())
    org_id           BigInt
    created_by       BigInt
    createdByUser    User                @relation("CustomerCreatedBy", fields: [created_by], references: [id])
    first_name       String?
    last_name        String?
    email            String?
    phone            String?
    aadhaar_number   String?
    pan_number       String?
    address          String?
    created_at       DateTime            @default(now())
    updated_at       DateTime            @updatedAt
    organization     Organization        @relation(fields: [org_id], references: [id])
    loanDetails      ProductLoan[]
    sipDetails       ProductSip[]
    mfDetails        ProductMutualFund[]
    fdDetails        ProductFd[]
    insuranceDetails ProductInsurance[]

    @@index([first_name, last_name, email, phone, aadhaar_number, pan_number])
    @@map("tbl_customer")
}

/**
 * ============================================================
 * PRODUCT TYPE
 * ==============================================================
 */

model ProductType {
    id         BigInt          @id @default(autoincrement())
    name       String          @unique
    status     Status          @default(ACTIVE)
    created_at DateTime        @default(now())
    updated_at DateTime        @updatedAt
    entities   ProductEntity[]

    @@index([name, status])
    @@map("tbl_product_type")
}

/**
 * ============================================================
 * PRODUCT ENTITY
 * ==============================================================
 */

model ProductEntity {
    id                   BigInt               @id @default(autoincrement())
    name                 String
    product_type_id      BigInt
    productType          ProductType          @relation(fields: [product_type_id], references: [id])
    status               Status               @default(ACTIVE)
    created_at           DateTime             @default(now())
    updated_at           DateTime             @updatedAt
    agentProductEntities AgentProductEntity[]
    loanDetails          ProductLoan[]
    sipDetails           ProductSip[]
    mfDetails            ProductMutualFund[]
    fdDetails            ProductFd[]
    insuranceDetails     ProductInsurance[]

    @@index([name, product_type_id, status])
    @@map("tbl_product_entity")
}

/**
 * ============================================================
 * AGENT PRODUCT ENTITY (PIVOT)
 * ==============================================================
 */

model AgentProductEntity {
    id                BigInt        @id @default(autoincrement())
    agent_id          BigInt
    agent             User          @relation(fields: [agent_id], references: [id])
    product_entity_id BigInt
    productEntity     ProductEntity @relation(fields: [product_entity_id], references: [id])
    created_at        DateTime      @default(now())
    updated_at        DateTime      @updatedAt

    @@unique([agent_id, product_entity_id])
    @@index([agent_id, product_entity_id])
    @@map("tbl_agent_product_entity")
}

/**
 * ============================================================
 * PRODUCT DETAILS TABLES
 * ==============================================================
 */

model ProductLoan {
    id                 BigInt        @id @default(autoincrement())
    customer_id        BigInt
    customer           Customer      @relation(fields: [customer_id], references: [id])
    product_entity_id  BigInt
    productEntity      ProductEntity @relation(fields: [product_entity_id], references: [id])
    agent_id           BigInt
    agent              User          @relation(fields: [agent_id], references: [id])
    loan_type          String?
    loan_amount        Float?
    interest_rate      Float?
    tenure_months      Int?
    emi_amount         Float?
    emi_due_day        Int?
    start_date         DateTime?
    end_date           DateTime?
    collateral_details String?
    status             Status        @default(ACTIVE)
    notes              String?
    created_at         DateTime      @default(now())
    updated_at         DateTime      @updatedAt

    @@index([customer_id, product_entity_id, agent_id, loan_type, status])
    @@map("tbl_product_loan")
}

model ProductSip {
    id                      BigInt        @id @default(autoincrement())
    customer_id             BigInt
    customer                Customer      @relation(fields: [customer_id], references: [id])
    product_entity_id       BigInt
    productEntity           ProductEntity @relation(fields: [product_entity_id], references: [id])
    agent_id                BigInt
    agent                   User          @relation(fields: [agent_id], references: [id])
    folio_number            String?
    scheme_name             String?
    start_date              DateTime?
    sip_amount              Float?
    frequency               String?
    tenure_months           Int?
    expected_maturity_value Float?
    risk_profile            String?
    notes                   String?
    created_at              DateTime      @default(now())
    updated_at              DateTime      @updatedAt

    @@index([customer_id, product_entity_id, agent_id, scheme_name, frequency])
    @@map("tbl_product_sip")
}

model ProductMutualFund {
    id                BigInt        @id @default(autoincrement())
    customer_id       BigInt
    customer          Customer      @relation(fields: [customer_id], references: [id])
    product_entity_id BigInt
    productEntity     ProductEntity @relation(fields: [product_entity_id], references: [id])
    agent_id          BigInt
    agent             User          @relation(fields: [agent_id], references: [id])
    folio_number      String?
    scheme_name       String?
    nav               Float?
    units             Float?
    investment_amount Float?
    purchase_date     DateTime?
    investment_type   String?
    risk_profile      String?
    notes             String?
    created_at        DateTime      @default(now())
    updated_at        DateTime      @updatedAt

    @@index([customer_id, product_entity_id, agent_id, folio_number, investment_type])
    @@map("tbl_product_mutual_fund")
}

model ProductFd {
    id                BigInt        @id @default(autoincrement())
    customer_id       BigInt
    customer          Customer      @relation(fields: [customer_id], references: [id])
    product_entity_id BigInt
    productEntity     ProductEntity @relation(fields: [product_entity_id], references: [id])
    agent_id          BigInt
    agent             User          @relation(fields: [agent_id], references: [id])
    fd_number         String?
    amount            Float?
    interest_rate     Float?
    tenure_months     Int?
    start_date        DateTime?
    maturity_date     DateTime?
    maturity_amount   Float?
    payout_frequency  String?
    nominee_name      String?
    notes             String?
    created_at        DateTime      @default(now())
    updated_at        DateTime      @updatedAt

    @@index([customer_id, product_entity_id, agent_id, fd_number, payout_frequency])
    @@map("tbl_product_fd")
}

model ProductInsurance {
    id                BigInt        @id @default(autoincrement())
    customer_id       BigInt
    customer          Customer      @relation(fields: [customer_id], references: [id])
    product_entity_id BigInt
    productEntity     ProductEntity @relation(fields: [product_entity_id], references: [id])
    agent_id          BigInt
    agent             User          @relation(fields: [agent_id], references: [id])
    policy_number     String?
    policy_type       String?
    sum_assured       Float?
    premium_amount    Float?
    premium_frequency String?
    issue_date        DateTime?
    start_date        DateTime?
    end_date          DateTime?
    nominee_name      String?
    status            Status        @default(ACTIVE)
    notes             String?
    created_at        DateTime      @default(now())
    updated_at        DateTime      @updatedAt

    @@index([customer_id, product_entity_id, agent_id, policy_number, policy_type, status])
    @@map("tbl_product_insurance")
}

/**
 * ============================================================
 * RAZORPAY
 * ==============================================================
 */

model RazorpayOrder {
    id           BigInt            @id @default(autoincrement())
    org_id       BigInt
    organization Organization      @relation(fields: [org_id], references: [id])
    order_id     String            @unique
    amount       Float
    currency     String            @default("INR")
    status       PaymentStatus     @default(created)
    receipt      String?
    created_at   DateTime          @default(now())
    updated_at   DateTime          @updatedAt
    payments     RazorpayPayment[]

    @@index([org_id, order_id, status])
    @@map("tbl_razorpay_order")
}

model RazorpayPayment {
    id                  BigInt        @id @default(autoincrement())
    order_id            BigInt
    order               RazorpayOrder @relation(fields: [order_id], references: [id])
    razorpay_payment_id String        @unique
    amount              Float?
    status              PaymentStatus @default(created)
    method              String?
    email               String?
    contact             String?
    created_at          DateTime      @default(now())
    updated_at          DateTime      @updatedAt

    @@index([order_id, razorpay_payment_id, status, method])
    @@map("tbl_razorpay_payment")
}

model RazorpaySubscriptionEvent {
    id                       BigInt                        @id @default(autoincrement())
    razorpay_subscription_id String?
    subscription             Subscription?                 @relation(fields: [razorpay_subscription_id], references: [razorpaySubscriptionId])
    event_type               RazorpaySubscriptionEventType
    payload                  Json?
    created_at               DateTime                      @default(now())
    updated_at               DateTime                      @updatedAt

    @@index([razorpay_subscription_id, event_type])
    @@map("tbl_razorpay_subscription_event")
}
