// prisma/schema.prisma

// generator client {
//     provider = "prisma-client-js"
// }

generator client {
    provider        = "prisma-client-js"
    output          = "../generated/prisma"
    previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

/**
 * ============================================================
 * ENUMS
 * ==============================================================
 */

enum AuthType {
    GOOGLE
    APPLE
    EMAIL_OTP
    PHONE_OTP
    EMAIL_PW
}

enum RoleName {
    OWNER
    ADMIN
    AGENT
}

enum Status {
    ACTIVE
    INACTIVE
}

enum ApprovalStatus {
    PENDING
    APPROVED
    REJECTED
}

enum OnboardingStatus {
    INCOMPLETED
    ONGOING
    COMPLETED
}

enum CustomerStatus {
    NEW_LEAD
    CONTACTED
    QUALIFIED
    PROPOSAL_SENT
    CONVERTED
    UNQUALIFIED
    FOLLOW_UP
    LOST
}

enum SubscriptionCycle {
    WEEKLY
    MONTHLY
    QUARTERLY
    YEARLY
}

enum MeetingStatus {
    SCHEDULED
    POSTPONED
    COMPLETED
    CANCELLED
}

enum MeetingType {
    REMINDER
    FOLLOW_UP
    CALL
    VISIT
}

enum Priority {
    LOW
    MEDIUM
    HIGH
}

/**
 * ============================================================
 * AUTH MODELS (ADDED)
 * ==============================================================
 */

model UserSession {
    id                      BigInt    @id @default(autoincrement())
    session_id              String    @unique
    user_id                 BigInt
    user                    User      @relation(fields: [user_id], references: [id])
    org_id                  BigInt?
    device_info             Json?
    ip_address              String?
    refresh_token_hash      String
    refresh_token_encrypted String?
    created_at              DateTime  @default(now())
    expires_at              DateTime
    last_used_at            DateTime?
    revoked                 Boolean   @default(false)

    @@index([session_id, user_id, org_id, ip_address, revoked])
    @@map("tbl_user_session")
}

/**
 * ============================================================
 * ROLE
 * ==============================================================
 */

model Role {
    id                BigInt             @id @default(autoincrement())
    name              RoleName           @unique
    description       String?
    created_at        DateTime           @default(now())
    organizationUsers OrganizationUser[]
    users             User[]

    @@index([name])
    @@map("tbl_role")
}

/**
 * ============================================================
 * USER
 * ==============================================================
 */

model AdminSettings {
    id         BigInt   @id @default(autoincrement()) @db.BigInt
    title      String
    metadata   Json
    created_at DateTime @default(now())
    updated_at DateTime @updatedAt()

    @@index([title])
    @@map("tbl_admin_settings")
}

model Country {
    id             BigInt   @id @default(autoincrement())
    name           String
    region         String?
    iso_code       String   @unique
    phoneLength    Int
    phone_code     String?
    timezone       String
    utc_offset_min Int
    status         Status   @default(ACTIVE)
    image          String?
    created_at     DateTime @default(now())
    updated_at     DateTime @updatedAt

    user      User[]
    customers Customer[]

    @@index([name, iso_code, phone_code, status])
    @@map("tbl_country")
}

model Currency {
    id            BigInt   @id @default(autoincrement())
    name          String
    code          String   @unique
    symbol        String
    exchange_rate Decimal? @default(0)
    status        Status   @default(ACTIVE)
    created_at    DateTime @default(now())
    updated_at    DateTime @updatedAt

    user              User[]
    subscriptionPlans SubscriptionPlan[]

    @@index([name, code, symbol, exchange_rate])
    @@map("tbl_currency")
}

model FAQ {
    id         BigInt    @id @default(autoincrement()) @db.BigInt
    question   String
    answer     String    @db.Text()
    rank       BigInt    @default(autoincrement()) @db.BigInt
    module_id  BigInt    @default(1)
    module     FAQModule @relation(fields: [module_id], references: [id])
    status     Status    @default(ACTIVE)
    created_at DateTime  @default(now())

    @@index([id, question, answer, rank, status])
    @@map("tbl_faqs")
}

model FAQModule {
    id         BigInt   @id @default(autoincrement()) @db.BigInt
    name       String   @db.Text()
    desc       String?  @db.Text()
    rank       BigInt   @default(autoincrement()) @db.BigInt
    status     Status   @default(ACTIVE)
    created_at DateTime @default(now())
    FAQ        FAQ[]

    @@index([id, name, rank, status])
    @@map("tbl_faq_modules")
}

model DynamicPage {
    id          BigInt   @id @default(autoincrement()) @db.BigInt
    title       String   @db.VarChar(255)
    slug        String   @unique @db.VarChar(255)
    description String?  @db.Text
    isActive    Boolean  @default(true)
    created_at  DateTime @default(now())
    updated_at  DateTime @updatedAt()

    @@unique([id])
    @@map("tbl_dynamic_pages")
}

model MenuType {
    id               BigInt     @id @default(autoincrement()) @db.BigInt
    name             String
    slug             String     @unique @db.VarChar(255)
    parent_menu_type BigInt?
    parent_relation  MenuType?  @relation("parent", fields: [parent_menu_type], references: [id])
    sub_menu_types   MenuType[] @relation("parent")
    menu             Menu[]
    created_at       DateTime   @default(now())
    updated_at       DateTime   @updatedAt()

    @@index([id, name, slug])
    @@map("tbl_menu_types")
}

model Menu {
    id             BigInt   @id @default(autoincrement()) @db.BigInt
    menu_type_id   BigInt
    menu_type      MenuType @relation(fields: [menu_type_id], references: [id])
    menu_item_id   BigInt
    menu_item_type String
    status         Status   @default(ACTIVE)
    path           String
    display_rank   Int?
    created_at     DateTime @default(now())
    updated_at     DateTime @updatedAt()

    @@index([id, menu_type_id, menu_item_id, path])
    @@map("tbl_menu")
}

model MetaData {
    id         BigInt   @id @default(autoincrement()) @db.BigInt
    table_id   BigInt
    table_name String
    key        String
    value      String
    created_at DateTime @default(now())
    updated_at DateTime @updatedAt()

    @@index([id, table_id, table_name, key])
    @@map("tbl_meta_data")
}

model User {
    id                      BigInt                  @id @default(autoincrement())
    first_name              String?
    last_name               String?
    email                   String?                 @unique
    password                String?                 @db.Text()
    role_id                 BigInt
    role                    Role                    @relation(fields: [role_id], references: [id])
    phone_no                String?
    image                   String?
    dob                     DateTime?
    auth_method             AuthType
    provider_id             String?                 @unique
    status                  Status                  @default(ACTIVE)
    refresh_token           String?
    reset_token             String?                 @unique
    reset_token_exp         DateTime?
    country_id              BigInt
    country                 Country                 @relation(fields: [country_id], references: [id])
    currency_id             BigInt
    currency                Currency                @relation(fields: [currency_id], references: [id])
    is_temporary            Boolean                 @default(false)
    is_deleted              Boolean                 @default(false)
    created_at              DateTime                @default(now())
    updated_at              DateTime                @updatedAt
    onboardingStatus        OnboardingStatus        @default(INCOMPLETED)
    invalidatedTokens       InvalidatedToken[]
    userFCMTokens           UserFCMToken[]
    organizations           Organization[]          @relation("OrgCreatedBy")
    orgUsers                OrganizationUser[]
    customers               Customer[]              @relation("CustomerCreatedBy")
    customerStatusHistories CustomerStatusHistory[] @relation("changedByAgent")
    agentProductEntities    AgentProductEntity[]
    sessions                UserSession[]
    agentKYC                AgentKYC?
    agentSales              AgentSale[]
    meetings                Meeting[]
    inAppNotifications      InAppNotifications[]
    toDos                   ToDo[]

    @@index([first_name, last_name, email, phone_no, auth_method, country_id, currency_id])
    @@map("tbl_user")
}

model AgentKYC {
    id             BigInt         @id @default(autoincrement())
    agent_id       BigInt         @unique
    agent          User           @relation(fields: [agent_id], references: [id])
    kyc_status     ApprovalStatus @default(PENDING)
    pan_number     String
    pan_image      String?
    aadhar_number  String
    aadhar_front   String?
    aadhar_back    String?
    bank_name      String
    account_number String
    branch_name    String
    ifsc_code      String
    upi_id         String?
    qr_code        String?
    base_img_path  String?
    created_at     DateTime       @default(now())
    updated_at     DateTime       @updatedAt

    @@index([pan_number, aadhar_number, bank_name, branch_name, ifsc_code, upi_id])
    @@map("tbl_agent_kyc")
}

model OTP {
    id             String    @id @default(uuid())
    credential     String    @unique
    otp            String
    limit          Int       @default(0)
    is_email       Boolean   @default(true)
    restrictedTime DateTime?
    created_at     DateTime  @default(now())
    expires_at     DateTime
    updated_at     DateTime  @updatedAt()

    @@index([credential])
    @@map("tbl_otp")
}

model InvalidatedToken {
    id         String   @id @default(uuid())
    token      String
    expires_at DateTime
    user_id    BigInt
    user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

    @@index([user_id])
    @@map("tbl_invalidated_tokens")
}

model UserFCMToken {
    id         BigInt   @id @default(autoincrement()) @db.BigInt
    user_id    BigInt
    user       User     @relation(fields: [user_id], references: [id])
    token      String
    created_at DateTime @default(now())
    updated_at DateTime @updatedAt

    @@map("tbl_user_fcm_tokens")
}

model InAppNotifications {
    id         BigInt   @id @default(autoincrement()) @db.BigInt
    user_id    BigInt
    user       User     @relation(fields: [user_id], references: [id])
    type       String
    title      String
    desc       String
    image      String?
    is_read    Boolean  @default(false)
    metadata   Json?
    created_at DateTime @default(now())

    @@index([user_id, type, title, desc, is_read])
    @@map("tbl_in_app_notifications")
}

model PushNotification {
    id         BigInt   @id @default(autoincrement()) @db.BigInt
    title      String
    body       String
    url        String?
    type       String?
    images     String?
    created_at DateTime @default(now())
    updated_at DateTime @updatedAt

    @@index([id])
    @@map("tbl_push_notifications")
}

/**
 * ============================================================
 * ORGANIZATION
 * ==============================================================
 */

model Organization {
    id            BigInt                     @id @default(autoincrement())
    name          String
    gst_number    String?
    pan_number    String?
    contact_email String?
    contact_phone String?
    status        Status                     @default(ACTIVE)
    created_by    BigInt                     @unique
    createdByUser User                       @relation("OrgCreatedBy", fields: [created_by], references: [id])
    created_at    DateTime                   @default(now())
    updated_at    DateTime                   @updatedAt
    subscription  OrganizationSubscription[]
    agentSales    AgentSale[]
    users         OrganizationUser[]
    customers     Customer[]
    toDos         ToDo[]

    @@index([name, gst_number, pan_number, contact_email, contact_phone])
    @@map("tbl_organization")
}

/**
 * ============================================================
 * ORGANIZATION USER (PIVOT)
 * ==============================================================
 */

model OrganizationUser {
    id           BigInt       @id @default(autoincrement())
    org_id       BigInt
    organization Organization @relation(fields: [org_id], references: [id])
    user_id      BigInt
    user         User         @relation(fields: [user_id], references: [id])
    role_id      BigInt
    role         Role         @relation(fields: [role_id], references: [id])
    status       Status       @default(ACTIVE)
    is_owner     Boolean      @default(false)
    created_at   DateTime     @default(now())
    updated_at   DateTime     @updatedAt

    @@unique([org_id, user_id])
    @@index([org_id, user_id, role_id, status])
    @@map("tbl_organization_user")
}

/**
 * ============================================================
 * CUSTOMER
 * ==============================================================
 */

model Customer {
    id               BigInt                  @id @default(autoincrement())
    org_id           BigInt
    organization     Organization            @relation(fields: [org_id], references: [id])
    created_by       BigInt
    createdByUser    User                    @relation("CustomerCreatedBy", fields: [created_by], references: [id])
    first_name       String?
    last_name        String?
    email            String?
    phone            String?
    country_id       BigInt?
    country          Country?                @relation(fields: [country_id], references: [id])
    image            String?
    aadhaar_number   String?
    pan_number       String?
    panImage         String?
    aadharFront      String?
    aadharBack       String?
    address          String?
    status           CustomerStatus          @default(NEW_LEAD)
    base_folder_path String?
    created_at       DateTime                @default(now())
    updated_at       DateTime                @updatedAt
    agentSales       AgentSale[]
    meetings         Meeting[]
    statusHistories  CustomerStatusHistory[]

    @@index([first_name, last_name, email, phone, aadhaar_number, pan_number])
    @@map("tbl_customer")
}

model CustomerStatusHistory {
    id             BigInt         @id @default(autoincrement())
    customer_id    BigInt
    customer       Customer       @relation(fields: [customer_id], references: [id], onDelete: Cascade)
    old_status     CustomerStatus
    new_status     CustomerStatus
    changed_by     BigInt
    changedByAgent User           @relation("changedByAgent", fields: [changed_by], references: [id])
    reason         String?
    created_at     DateTime       @default(now())

    @@map("tbl_customer_status_history")
}

/**
 * ============================================================
 * PRODUCT TYPE
 * ==============================================================
 */

model Products {
    id         BigInt          @id @default(autoincrement())
    name       String          @unique
    slug       String          @unique
    desc       String?
    image      String?
    status     Status          @default(ACTIVE)
    created_at DateTime        @default(now())
    updated_at DateTime        @updatedAt
    entities   ProductEntity[]

    @@index([name, status])
    @@map("tbl_products")
}

/**
 * ============================================================
 * PRODUCT ENTITY
 * ==============================================================
 */

model ProductEntity {
    id                   BigInt               @id @default(autoincrement())
    name                 String
    slug                 String               @unique
    desc                 String?
    image                String?
    product_id           BigInt
    products             Products             @relation(fields: [product_id], references: [id])
    status               Status               @default(ACTIVE)
    created_at           DateTime             @default(now())
    updated_at           DateTime             @updatedAt
    agentSales           AgentSale[]
    agentProductEntities AgentProductEntity[]

    @@index([name, slug, product_id, status])
    @@map("tbl_product_entity")
}

/**
 * ============================================================
 * AGENT PRODUCT ENTITY (PIVOT)
 * ==============================================================
 */

model AgentProductEntity {
    id                BigInt        @id @default(autoincrement())
    agent_id          BigInt
    agent             User          @relation(fields: [agent_id], references: [id])
    product_entity_id BigInt
    productEntity     ProductEntity @relation(fields: [product_entity_id], references: [id])
    created_at        DateTime      @default(now())
    updated_at        DateTime      @updatedAt

    @@unique([agent_id, product_entity_id])
    @@index([agent_id, product_entity_id])
    @@map("tbl_agent_product_entity")
}

/**
 * ============================================================
 * PRODUCT DETAILS TABLES
 * ==============================================================
 */

model AgentSale {
    id                BigInt               @id @default(autoincrement())
    org_id            BigInt?
    organization      Organization?        @relation(fields: [org_id], references: [id])
    agent_id          BigInt
    agent             User                 @relation(fields: [agent_id], references: [id])
    customer_id       BigInt
    customer          Customer             @relation(fields: [customer_id], references: [id])
    product_entity_id BigInt
    productEntity     ProductEntity        @relation(fields: [product_entity_id], references: [id])
    sale_date         DateTime             @default(now())
    status            Status               @default(ACTIVE)
    created_at        DateTime             @default(now())
    updated_at        DateTime             @updatedAt
    fixedDeposit      ProductFixedDeposit?
    insurance         ProductInsurance?
    mutualFund        ProductMutualFund?
    realEstate        ProductRealEstate?
    saleDocuments     SaleDocument[]

    @@index([agent_id, customer_id, product_entity_id, sale_date, status])
    @@map("tbl_agent_sale")
}

model ProductFixedDeposit {
    id                    BigInt    @id @default(autoincrement())
    sale_id               BigInt    @unique
    sale                  AgentSale @relation(fields: [sale_id], references: [id])
    product_type          String
    scheme_name           String
    account_number        BigInt?
    ifsc_code             String?
    bank_name             String?
    branch_name           String?
    deposit_amount        String?
    interest_rate         String?
    tenure_months         Int?
    start_date            DateTime?
    maturity_date         DateTime?
    maturity_amount       String?
    payout_type           String?
    nominee_name          String?
    nominee_relationship  String?
    commission_percentage String?
    kyc_status            String?
    application_status    String?
    remarks               String?
    documents             String[]
    created_at            DateTime  @default(now())
    updated_at            DateTime  @updatedAt

    @@index([product_type, bank_name])
    @@map("tbl_product_fixed_deposit")
}

model ProductInsurance {
    id                          BigInt    @id @default(autoincrement())
    sale_id                     BigInt    @unique
    sale                        AgentSale @relation(fields: [sale_id], references: [id])
    insurance_type              String
    insurance_company_name      String
    policy_number               String?
    sum_assured                 String?
    premium_amount              String?
    premium_payment_frequency   String?
    policy_term_years           Int?
    policy_start_date           DateTime?
    policy_end_date             DateTime?
    pre_existing_diseases       String?
    smoking_status              String?
    height                      String?
    weight                      String?
    vehicle_type                String?
    vehicle_registration_number String?
    vehicle_make                String?
    vehicle_model               String?
    manufacturing_year          Int?
    engine_number               String?
    chassis_number              String?
    fuel_type                   String?
    cubic_capacity_cc           Int?
    insured_declared_value      String?
    no_claim_bonus              String?
    nominee_name                String?
    nominee_relationship        String?
    commission_percentage       String?
    kyc_status                  String?
    proposal_status             String?
    documents                   String[]
    created_at                  DateTime  @default(now())
    updated_at                  DateTime  @updatedAt

    @@index([insurance_type, policy_number])
    @@map("tbl_product_insurance")
}

model ProductMutualFund {
    id                    BigInt    @id @default(autoincrement())
    sale_id               BigInt    @unique
    sale                  AgentSale @relation(fields: [sale_id], references: [id])
    fund_type             String
    fund_sub_type         String?
    amc_name              String?
    scheme_name           String?
    folio_number          String?
    investment_mode       String?
    investment_amount     String?
    sip_amount            String?
    sip_frequency         String?
    start_date            DateTime?
    units_allocated       String?
    nav_at_purchase       String?
    current_value         String?
    commission_percentage String?
    commission_amount     String?
    kyc_status            String?
    fatca_status          String?
    nominee_name          String?
    nominee_relationship  String?
    documents             String[]
    created_at            DateTime  @default(now())
    updated_at            DateTime  @updatedAt

    @@index([fund_type, scheme_name])
    @@map("tbl_product_mutual_fund")
}

model ProductRealEstate {
    id                       BigInt    @id @default(autoincrement())
    sale_id                  BigInt    @unique
    sale                     AgentSale @relation(fields: [sale_id], references: [id])
    property_type            String
    transaction_type         String
    property_title           String
    property_address         String
    city                     String
    state                    String
    pincode                  String
    super_build_up_area_sqft String?
    build_up_area_sqft       String?
    carpet_area_sqft         String?
    land_area                String?
    bhk                      String?
    price                    String?
    booking_amount           String?
    builder_name             String?
    rera_number              String?
    ownership_type           String?
    loan_required            Boolean?  @default(false)
    commission_percentage    String?
    commission_amount        String?
    documents                String[]
    created_at               DateTime  @default(now())
    updated_at               DateTime  @updatedAt

    @@index([property_type, city])
    @@map("tbl_product_real_estate")
}

model SaleDocument {
    id           BigInt          @id @default(autoincrement())
    sale_id      BigInt
    sale         AgentSale       @relation(fields: [sale_id], references: [id], onDelete: Cascade)
    product_type SaleProductType
    file_path    String
    file_name    String?
    mime_type    String?
    uploaded_by  BigInt?
    uploaded_at  DateTime        @default(now())
    deleted_at   DateTime?
    deleted_by   BigInt?

    @@index([sale_id])
    @@map("tbl_sale_documents")
}

enum SaleProductType {
    FIXED_DEPOSIT
    INSURANCE
    MUTUAL_FUND
    REAL_ESTATE
}

/**
 * ============================================================
 * RAZORPAY SUBSCRIPTION
 * ==============================================================
 */
model SubscriptionPlan {
    id                   BigInt                     @id @default(autoincrement())
    code                 String                     @unique
    name                 String
    description          String?
    price                Int
    currency_id          BigInt
    currency             Currency                   @relation(fields: [currency_id], references: [id])
    billing_cycle        SubscriptionCycle
    max_customers        Int?
    rzp_plan_id          String?                    @unique
    is_active            Boolean                    @default(true)
    is_popular           Boolean                    @default(false)
    created_at           DateTime                   @default(now())
    updated_at           DateTime                   @updatedAt
    subscriptions        OrganizationSubscription[]
    subscriptionFeatures SubscriptionFeature[]

    @@index([code, billing_cycle, is_active])
    @@map("tbl_subscription_plan")
}

