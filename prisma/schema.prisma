// prisma/schema.prisma

// generator client {
//     provider = "prisma-client-js"
// }

generator client {
    provider        = "prisma-client-js"
    output          = "../generated/prisma"
    previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

/**
 * ============================================================
 * ENUMS
 * ==============================================================
 */

enum AuthType {
    GOOGLE
    APPLE
    EMAIL_OTP
    PHONE_OTP
    EMAIL_PW
}

enum RoleName {
    OWNER
    ADMIN
    AGENT
}

enum Status {
    ACTIVE
    INACTIVE
}

enum ApprovalStatus {
    PENDING
    APPROVED
    REJECTED
}

enum SubscriptionStatus {
    active
    paused
    cancelled
}

enum PaymentStatus {
    created
    paid
    failed
}

enum SubscriptionCycle {
    WEEKLY
    MONTHLY
    QUARTERLY
    YEARLY
}

enum RazorpaySubscriptionEventType {
    activated
    charged_at
    completed
    halted
    cancelled
}

/**
 * ============================================================
 * AUTH MODELS (ADDED)
 * ==============================================================
 */

model UserSession {
    id                      BigInt    @id @default(autoincrement())
    session_id              String    @unique
    user_id                 BigInt
    user                    User      @relation(fields: [user_id], references: [id])
    org_id                  BigInt?
    device_info             Json?
    ip_address              String?
    refresh_token_hash      String
    refresh_token_encrypted String?
    created_at              DateTime  @default(now())
    expires_at              DateTime
    last_used_at            DateTime?
    revoked                 Boolean   @default(false)

    @@index([session_id, user_id, org_id, ip_address, revoked])
    @@map("tbl_user_session")
}

/**
 * ============================================================
 * ROLE
 * ==============================================================
 */

model Role {
    id                BigInt             @id @default(autoincrement())
    name              RoleName           @unique
    description       String?
    created_at        DateTime           @default(now())
    organizationUsers OrganizationUser[]
    users             User[]

    @@index([name])
    @@map("tbl_role")
}

/**
 * ============================================================
 * USER
 * ==============================================================
 */

model AdminSettings {
    id         BigInt   @id @default(autoincrement()) @db.BigInt
    title      String
    metadata   Json
    created_at DateTime @default(now())
    updated_at DateTime @updatedAt()

    @@index([title])
    @@map("tbl_admin_settings")
}

model Country {
    id             BigInt   @id @default(autoincrement())
    name           String
    region         String?
    iso_code       String   @unique
    phoneLength    Int
    phone_code     String?
    timezone       String
    utc_offset_min Int
    status         Status   @default(ACTIVE)
    image          String?
    created_at     DateTime @default(now())
    updated_at     DateTime @updatedAt

    user User[]

    @@index([name, iso_code, phone_code, status])
    @@map("tbl_country")
}

model Currency {
    id            BigInt   @id @default(autoincrement())
    name          String
    code          String   @unique
    symbol        String
    exchange_rate Decimal? @default(0)
    status        Status   @default(ACTIVE)
    created_at    DateTime @default(now())
    updated_at    DateTime @updatedAt

    user User[]

    @@index([name, code, symbol, exchange_rate])
    @@map("tbl_currency")
}

model FAQ {
    id         BigInt    @id @default(autoincrement()) @db.BigInt
    question   String
    answer     String    @db.Text()
    rank       BigInt    @default(autoincrement()) @db.BigInt
    module_id  BigInt    @default(1)
    module     FAQModule @relation(fields: [module_id], references: [id])
    status     Status    @default(ACTIVE)
    created_at DateTime  @default(now())

    @@index([id, question, answer, rank, status])
    @@map("tbl_faqs")
}

model FAQModule {
    id         BigInt   @id @default(autoincrement()) @db.BigInt
    name       String   @db.Text()
    desc       String?  @db.Text()
    rank       BigInt   @default(autoincrement()) @db.BigInt
    status     Status   @default(ACTIVE)
    created_at DateTime @default(now())
    FAQ        FAQ[]

    @@index([id, name, rank, status])
    @@map("tbl_faq_modules")
}

model DynamicPage {
    id          BigInt   @id @default(autoincrement()) @db.BigInt
    title       String   @db.VarChar(255)
    slug        String   @unique @db.VarChar(255)
    description String?  @db.Text
    isActive    Boolean  @default(true)
    created_at  DateTime @default(now())
    updated_at  DateTime @updatedAt()

    @@unique([id])
    @@map("tbl_dynamic_pages")
}

model MenuType {
    id               BigInt     @id @default(autoincrement()) @db.BigInt
    name             String
    slug             String     @unique @db.VarChar(255)
    parent_menu_type BigInt?
    parent_relation  MenuType?  @relation("parent", fields: [parent_menu_type], references: [id])
    sub_menu_types   MenuType[] @relation("parent")
    menu             Menu[]
    created_at       DateTime   @default(now())
    updated_at       DateTime   @updatedAt()

    @@index([id])
    @@map("tbl_menu_types")
}

model Menu {
    id             BigInt   @id @default(autoincrement()) @db.BigInt
    menu_type_id   BigInt
    menu_type      MenuType @relation(fields: [menu_type_id], references: [id])
    menu_item_id   BigInt
    menu_item_type String
    status         Status   @default(ACTIVE)
    path           String
    display_rank   Int?
    created_at     DateTime @default(now())
    updated_at     DateTime @updatedAt()

    @@index([id, menu_type_id, menu_item_id, path])
    @@map("tbl_menu")
}

model MetaData {
    id         BigInt   @id @default(autoincrement()) @db.BigInt
    table_id   BigInt
    table_name String
    key        String
    value      String
    created_at DateTime @default(now())
    updated_at DateTime @updatedAt()

    @@index([id, table_id, table_name, key])
    @@map("tbl_meta_data")
}

model User {
    id                   BigInt               @id @default(autoincrement())
    first_name           String?
    last_name            String?
    email                String?              @unique
    password             String?              @db.Text()
    role_id              BigInt
    role                 Role                 @relation(fields: [role_id], references: [id])
    phone_no             String?
    image                String?
    provider             AuthType
    provider_id          String?
    status               Status               @default(ACTIVE)
    refresh_token        String?
    reset_token          String?              @unique
    reset_token_exp      DateTime?
    country_id           BigInt
    country              Country              @relation(fields: [country_id], references: [id])
    currency_id          BigInt
    currency             Currency             @relation(fields: [currency_id], references: [id])
    is_temporary         Boolean              @default(false)
    is_deleted           Boolean              @default(false)
    created_at           DateTime             @default(now())
    updated_at           DateTime             @updatedAt
    invalidatedTokens    InvalidatedToken[]
    organizations        Organization[]       @relation("OrgCreatedBy")
    orgUsers             OrganizationUser[]
    customers            Customer[]           @relation("CustomerCreatedBy")
    agentProductEntities AgentProductEntity[]
    sessions             UserSession[]
    agentKYC             AgentKYC?
    agentSales           AgentSale[]

    @@index([first_name, last_name, email, phone_no, provider, country_id, currency_id])
    @@map("tbl_user")
}

model AgentKYC {
    id             BigInt         @id @default(autoincrement())
    agent_id       BigInt         @unique
    agent          User           @relation(fields: [agent_id], references: [id])
    kyc_status     ApprovalStatus @default(PENDING)
    pan_number     String
    pan_image      String
    aadhar_number  String
    aadhar_image   String
    bank_name      String
    account_number String
    branch_name    String
    ifsc_code      String
    upi_id         String?
    qr_code        String?
    created_at     DateTime       @default(now())
    updated_at     DateTime       @updatedAt

    @@index([pan_number, aadhar_number, bank_name, branch_name, ifsc_code, upi_id])
    @@map("tbl_agent_kyc")
}

model OTP {
    id             String    @id @default(uuid())
    credential     String    @unique
    otp            String
    limit          Int       @default(0)
    is_email       Boolean   @default(true)
    restrictedTime DateTime?
    created_at     DateTime  @default(now())
    expires_at     DateTime
    updated_at     DateTime  @updatedAt()

    @@index([credential])
    @@map("tbl_otp")
}

model InvalidatedToken {
    id         String   @id @default(uuid())
    token      String
    expires_at DateTime
    user_id    BigInt
    user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

    @@index([user_id])
    @@map("tbl_invalidated_tokens")
}

/**
 * ============================================================
 * ORGANIZATION
 * ==============================================================
 */

model Organization {
    id             BigInt             @id @default(autoincrement())
    name           String
    gst_number     String?
    pan_number     String?
    contact_email  String?
    contact_phone  String?
    created_by     BigInt
    createdByUser  User               @relation("OrgCreatedBy", fields: [created_by], references: [id])
    created_at     DateTime           @default(now())
    updated_at     DateTime           @updatedAt
    subscription   Subscription?
    agentSales     AgentSale[]
    users          OrganizationUser[]
    customers      Customer[]
    razorpayOrders RazorpayOrder[]

    @@index([name, gst_number, pan_number, contact_email, contact_phone])
    @@map("tbl_organization")
}

/**
 * ============================================================
 * ORGANIZATION USER (PIVOT)
 * ==============================================================
 */

model OrganizationUser {
    id           BigInt       @id @default(autoincrement())
    org_id       BigInt
    organization Organization @relation(fields: [org_id], references: [id])
    user_id      BigInt
    user         User         @relation(fields: [user_id], references: [id])
    role_id      BigInt
    role         Role         @relation(fields: [role_id], references: [id])
    status       Status       @default(ACTIVE)
    is_owner     Boolean      @default(false)
    created_at   DateTime     @default(now())
    updated_at   DateTime     @updatedAt

    @@unique([org_id, user_id])
    @@index([org_id, user_id, role_id, status])
    @@map("tbl_organization_user")
}

/**
 * ============================================================
 * SUBSCRIPTION PLAN
 * ==============================================================
 */

model SubscriptionPlan {
    id             BigInt            @id @default(autoincrement())
    name           String            @unique
    max_customers  Int
    price          Float
    billing_cycle  SubscriptionCycle @default(MONTHLY)
    razorpayPlanId String?           @unique
    created_at     DateTime          @default(now())
    updated_at     DateTime          @updatedAt
    subscriptions  Subscription[]

    @@index([name, billing_cycle, razorpayPlanId])
    @@map("tbl_subscription_plan")
}

/**
 * ============================================================
 * SUBSCRIPTION
 * ==============================================================
 */

model Subscription {
    id                     BigInt                      @id @default(autoincrement())
    org_id                 BigInt                      @unique
    organization           Organization                @relation(fields: [org_id], references: [id])
    plan_id                BigInt
    plan                   SubscriptionPlan            @relation(fields: [plan_id], references: [id])
    razorpaySubscriptionId String?                     @unique
    current_status         SubscriptionStatus          @default(active)
    start_date             DateTime
    end_date               DateTime
    auto_renew             Boolean                     @default(true)
    created_at             DateTime                    @default(now())
    updated_at             DateTime                    @updatedAt
    events                 RazorpaySubscriptionEvent[]

    @@index([org_id, plan_id, razorpaySubscriptionId, current_status, auto_renew])
    @@map("tbl_subscription")
}

/**
 * ============================================================
 * CUSTOMER
 * ==============================================================
 */

model Customer {
    id             BigInt       @id @default(autoincrement())
    org_id         BigInt
    organization   Organization @relation(fields: [org_id], references: [id])
    created_by     BigInt
    createdByUser  User         @relation("CustomerCreatedBy", fields: [created_by], references: [id])
    first_name     String?
    last_name      String?
    email          String?
    phone          String?
    image          String?
    aadhaar_number String?
    pan_number     String?
    address        String?
    created_at     DateTime     @default(now())
    updated_at     DateTime     @updatedAt
    agentSales     AgentSale[]

    @@index([first_name, last_name, email, phone, aadhaar_number, pan_number])
    @@map("tbl_customer")
}

/**
 * ============================================================
 * PRODUCT TYPE
 * ==============================================================
 */

model Products {
    id         BigInt          @id @default(autoincrement())
    name       String          @unique
    status     Status          @default(ACTIVE)
    created_at DateTime        @default(now())
    updated_at DateTime        @updatedAt
    entities   ProductEntity[]

    @@index([name, status])
    @@map("tbl_products")
}

/**
 * ============================================================
 * PRODUCT ENTITY
 * ==============================================================
 */

model ProductEntity {
    id                   BigInt               @id @default(autoincrement())
    name                 String
    slug                 String               @unique
    product_id           BigInt
    products             Products             @relation(fields: [product_id], references: [id])
    status               Status               @default(ACTIVE)
    created_at           DateTime             @default(now())
    updated_at           DateTime             @updatedAt
    agentSales           AgentSale[]
    agentProductEntities AgentProductEntity[]

    @@index([name, slug, product_id, status])
    @@map("tbl_product_entity")
}

/**
 * ============================================================
 * AGENT PRODUCT ENTITY (PIVOT)
 * ==============================================================
 */

model AgentProductEntity {
    id                BigInt        @id @default(autoincrement())
    agent_id          BigInt
    agent             User          @relation(fields: [agent_id], references: [id])
    product_entity_id BigInt
    productEntity     ProductEntity @relation(fields: [product_entity_id], references: [id])
    created_at        DateTime      @default(now())
    updated_at        DateTime      @updatedAt

    @@unique([agent_id, product_entity_id])
    @@index([agent_id, product_entity_id])
    @@map("tbl_agent_product_entity")
}

/**
 * ============================================================
 * PRODUCT DETAILS TABLES
 * ==============================================================
 */

model AgentSale {
    id                BigInt                   @id @default(autoincrement())
    org_id            BigInt?
    organization      Organization?            @relation(fields: [org_id], references: [id])
    agent_id          BigInt
    agent             User                     @relation(fields: [agent_id], references: [id])
    customer_id       BigInt
    customer          Customer                 @relation(fields: [customer_id], references: [id])
    product_entity_id BigInt
    productEntity     ProductEntity            @relation(fields: [product_entity_id], references: [id])
    sale_date         DateTime                 @default(now())
    status            Status                   @default(ACTIVE)
    created_at        DateTime                 @default(now())
    updated_at        DateTime                 @updatedAt
    lifeInsurance     ProductLifeInsurance?
    medicalInsurance  ProductMedicalInsurance?
    mutualFund        ProductMutualFund?
    realEstate        ProductRealEstate?

    @@index([agent_id, customer_id, product_entity_id, sale_date, status])
    @@map("tbl_agent_sale")
}

model ProductLifeInsurance {
    id                BigInt             @id @default(autoincrement())
    sale_id           BigInt             @unique
    sale              AgentSale          @relation(fields: [sale_id], references: [id])
    policy_number     String?
    plan_name         String?
    policy_type       String?
    sum_assured       Float?
    premium_amount    Float?
    premium_frequency SubscriptionCycle? @default(MONTHLY)
    policy_term       Int? // years
    payment_term      Int?
    issue_date        DateTime?
    start_date        DateTime?
    end_date          DateTime?
    nominee_name      String?
    nominee_relation  String?
    policy_status     Status             @default(ACTIVE)
    notes             String?
    created_at        DateTime           @default(now())
    updated_at        DateTime           @updatedAt

    @@index([policy_number, plan_name, policy_type, policy_status])
    @@map("tbl_product_life_insurance")
}

model ProductMedicalInsurance {
    id                   BigInt    @id @default(autoincrement())
    sale_id              BigInt    @unique
    sale                 AgentSale @relation(fields: [sale_id], references: [id])
    policy_number        String?
    plan_name            String?
    coverage_amount      Float?
    premium_amount       Float?
    policy_type          String? // Individual / Family Floater
    insured_members      Json? // [{name, age, relation}]
    pre_existing_disease String?
    waiting_period       Int? // months
    issue_date           DateTime?
    start_date           DateTime?
    end_date             DateTime?
    policy_status        Status    @default(ACTIVE)
    notes                String?
    created_at           DateTime  @default(now())
    updated_at           DateTime  @updatedAt

    @@index([policy_number, plan_name, policy_type, policy_status])
    @@map("tbl_product_medical_insurance")
}

model ProductMutualFund {
    id                BigInt    @id @default(autoincrement())
    sale_id           BigInt    @unique
    sale              AgentSale @relation(fields: [sale_id], references: [id])
    folio_number      String?
    scheme_name       String?
    fund_house        String?
    investment_type   String? // SIP / LUMPSUM
    investment_amount Float?
    nav               Float?
    units             Float?
    sip_start_date    DateTime?
    sip_end_date      DateTime?
    risk_profile      String?
    notes             String?
    created_at        DateTime  @default(now())
    updated_at        DateTime  @updatedAt

    @@index([folio_number, scheme_name, investment_type])
    @@map("tbl_product_mutual_fund")
}

model ProductRealEstate {
    id BigInt @id @default(autoincrement())

    sale_id         BigInt    @unique
    sale            AgentSale @relation(fields: [sale_id], references: [id])
    property_type   String? // Flat / Land / Commercial
    property_name   String?
    location        String?
    area_sqft       Float?
    property_value  Float?
    booking_amount  Float?
    builder_name    String?
    agreement_date  DateTime?
    possession_date DateTime?
    ownership_type  String?
    notes           String?
    created_at      DateTime  @default(now())
    updated_at      DateTime  @updatedAt

    @@index([property_type, location, property_name, builder_name, ownership_type])
    @@map("tbl_product_real_estate")
}

/**
 * ============================================================
 * RAZORPAY
 * ==============================================================
 */

model RazorpayOrder {
    id           BigInt            @id @default(autoincrement())
    org_id       BigInt
    organization Organization      @relation(fields: [org_id], references: [id])
    order_id     String            @unique
    amount       Float
    currency     String            @default("INR")
    status       PaymentStatus     @default(created)
    receipt      String?
    created_at   DateTime          @default(now())
    updated_at   DateTime          @updatedAt
    payments     RazorpayPayment[]

    @@index([org_id, order_id, status])
    @@map("tbl_razorpay_order")
}

model RazorpayPayment {
    id                  BigInt        @id @default(autoincrement())
    order_id            BigInt
    order               RazorpayOrder @relation(fields: [order_id], references: [id])
    razorpay_payment_id String        @unique
    amount              Float?
    status              PaymentStatus @default(created)
    method              String?
    email               String?
    contact             String?
    created_at          DateTime      @default(now())
    updated_at          DateTime      @updatedAt

    @@index([order_id, razorpay_payment_id, status, method])
    @@map("tbl_razorpay_payment")
}

model RazorpaySubscriptionEvent {
    id                       BigInt                        @id @default(autoincrement())
    razorpay_subscription_id String?
    subscription             Subscription?                 @relation(fields: [razorpay_subscription_id], references: [razorpaySubscriptionId])
    event_type               RazorpaySubscriptionEventType
    payload                  Json?
    created_at               DateTime                      @default(now())
    updated_at               DateTime                      @updatedAt

    @@index([razorpay_subscription_id, event_type])
    @@map("tbl_razorpay_subscription_event")
}
