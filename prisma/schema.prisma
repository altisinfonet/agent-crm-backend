// prisma/schema.prisma

// generator client {
//     provider = "prisma-client-js"
// }

generator client {
    provider        = "prisma-client-js"
    output          = "../generated/prisma"
    previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

/**
 * ============================================================
 * ENUMS
 * ==============================================================
 */

enum AuthType {
    GOOGLE
    APPLE
    EMAIL_OTP
    PHONE_OTP
    EMAIL_PW
}

enum RoleName {
    OWNER
    ADMIN
    AGENT
}

enum Status {
    ACTIVE
    INACTIVE
}

enum ApprovalStatus {
    PENDING
    APPROVED
    REJECTED
}

enum SubscriptionStatus {
    PENDING
    ACTIVE
    PAUSED
    UPGRADED
    CANCELLED
    EXPIRED
    HALTED
}

enum SubscriptionSource {
    RAZORPAY
    ADMIN
}

enum RazorpayEntityType {
    SUBSCRIPTION
    PAYMENT
    INVOICE
}

enum SubscriptionCycle {
    WEEKLY
    MONTHLY
    QUARTERLY
    YEARLY
}

enum MeetingStatus {
    SCHEDULED
    POSTPONED
    COMPLETED
    CANCELLED
}

enum MeetingType {
    REMINDER
    FOLLOW_UP
    CALL
    VISIT
}

enum Priority {
    LOW
    MEDIUM
    HIGH
}

/**
 * ============================================================
 * AUTH MODELS (ADDED)
 * ==============================================================
 */

model UserSession {
    id                      BigInt    @id @default(autoincrement())
    session_id              String    @unique
    user_id                 BigInt
    user                    User      @relation(fields: [user_id], references: [id])
    org_id                  BigInt?
    device_info             Json?
    ip_address              String?
    refresh_token_hash      String
    refresh_token_encrypted String?
    created_at              DateTime  @default(now())
    expires_at              DateTime
    last_used_at            DateTime?
    revoked                 Boolean   @default(false)

    @@index([session_id, user_id, org_id, ip_address, revoked])
    @@map("tbl_user_session")
}

/**
 * ============================================================
 * ROLE
 * ==============================================================
 */

model Role {
    id                BigInt             @id @default(autoincrement())
    name              RoleName           @unique
    description       String?
    created_at        DateTime           @default(now())
    organizationUsers OrganizationUser[]
    users             User[]

    @@index([name])
    @@map("tbl_role")
}

/**
 * ============================================================
 * USER
 * ==============================================================
 */

model AdminSettings {
    id         BigInt   @id @default(autoincrement()) @db.BigInt
    title      String
    metadata   Json
    created_at DateTime @default(now())
    updated_at DateTime @updatedAt()

    @@index([title])
    @@map("tbl_admin_settings")
}

model Country {
    id             BigInt   @id @default(autoincrement())
    name           String
    region         String?
    iso_code       String   @unique
    phoneLength    Int
    phone_code     String?
    timezone       String
    utc_offset_min Int
    status         Status   @default(ACTIVE)
    image          String?
    created_at     DateTime @default(now())
    updated_at     DateTime @updatedAt

    user User[]

    @@index([name, iso_code, phone_code, status])
    @@map("tbl_country")
}

model Currency {
    id            BigInt   @id @default(autoincrement())
    name          String
    code          String   @unique
    symbol        String
    exchange_rate Decimal? @default(0)
    status        Status   @default(ACTIVE)
    created_at    DateTime @default(now())
    updated_at    DateTime @updatedAt

    user              User[]
    subscriptionPlans SubscriptionPlan[]

    @@index([name, code, symbol, exchange_rate])
    @@map("tbl_currency")
}

model FAQ {
    id         BigInt    @id @default(autoincrement()) @db.BigInt
    question   String
    answer     String    @db.Text()
    rank       BigInt    @default(autoincrement()) @db.BigInt
    module_id  BigInt    @default(1)
    module     FAQModule @relation(fields: [module_id], references: [id])
    status     Status    @default(ACTIVE)
    created_at DateTime  @default(now())

    @@index([id, question, answer, rank, status])
    @@map("tbl_faqs")
}

model FAQModule {
    id         BigInt   @id @default(autoincrement()) @db.BigInt
    name       String   @db.Text()
    desc       String?  @db.Text()
    rank       BigInt   @default(autoincrement()) @db.BigInt
    status     Status   @default(ACTIVE)
    created_at DateTime @default(now())
    FAQ        FAQ[]

    @@index([id, name, rank, status])
    @@map("tbl_faq_modules")
}

model DynamicPage {
    id          BigInt   @id @default(autoincrement()) @db.BigInt
    title       String   @db.VarChar(255)
    slug        String   @unique @db.VarChar(255)
    description String?  @db.Text
    isActive    Boolean  @default(true)
    created_at  DateTime @default(now())
    updated_at  DateTime @updatedAt()

    @@unique([id])
    @@map("tbl_dynamic_pages")
}

model MenuType {
    id               BigInt     @id @default(autoincrement()) @db.BigInt
    name             String
    slug             String     @unique @db.VarChar(255)
    parent_menu_type BigInt?
    parent_relation  MenuType?  @relation("parent", fields: [parent_menu_type], references: [id])
    sub_menu_types   MenuType[] @relation("parent")
    menu             Menu[]
    created_at       DateTime   @default(now())
    updated_at       DateTime   @updatedAt()

    @@index([id])
    @@map("tbl_menu_types")
}

model Menu {
    id             BigInt   @id @default(autoincrement()) @db.BigInt
    menu_type_id   BigInt
    menu_type      MenuType @relation(fields: [menu_type_id], references: [id])
    menu_item_id   BigInt
    menu_item_type String
    status         Status   @default(ACTIVE)
    path           String
    display_rank   Int?
    created_at     DateTime @default(now())
    updated_at     DateTime @updatedAt()

    @@index([id, menu_type_id, menu_item_id, path])
    @@map("tbl_menu")
}

model MetaData {
    id         BigInt   @id @default(autoincrement()) @db.BigInt
    table_id   BigInt
    table_name String
    key        String
    value      String
    created_at DateTime @default(now())
    updated_at DateTime @updatedAt()

    @@index([id, table_id, table_name, key])
    @@map("tbl_meta_data")
}

model User {
    id                   BigInt               @id @default(autoincrement())
    first_name           String?
    last_name            String?
    email                String?              @unique
    password             String?              @db.Text()
    role_id              BigInt
    role                 Role                 @relation(fields: [role_id], references: [id])
    phone_no             String?
    image                String?
    dob                  DateTime?
    auth_method          AuthType
    provider_id          String?
    status               Status               @default(ACTIVE)
    refresh_token        String?
    reset_token          String?              @unique
    reset_token_exp      DateTime?
    country_id           BigInt
    country              Country              @relation(fields: [country_id], references: [id])
    currency_id          BigInt
    currency             Currency             @relation(fields: [currency_id], references: [id])
    is_temporary         Boolean              @default(false)
    is_deleted           Boolean              @default(false)
    created_at           DateTime             @default(now())
    updated_at           DateTime             @updatedAt
    invalidatedTokens    InvalidatedToken[]
    userFCMTokens        UserFCMToken[]
    organizations        Organization[]       @relation("OrgCreatedBy")
    orgUsers             OrganizationUser[]
    customers            Customer[]           @relation("CustomerCreatedBy")
    agentProductEntities AgentProductEntity[]
    sessions             UserSession[]
    agentKYC             AgentKYC?
    agentSales           AgentSale[]
    meetings             Meeting[]
    inAppNotifications   InAppNotifications[]
    toDos                ToDo[]

    @@index([first_name, last_name, email, phone_no, auth_method, country_id, currency_id])
    @@map("tbl_user")
}

model AgentKYC {
    id             BigInt         @id @default(autoincrement())
    agent_id       BigInt         @unique
    agent          User           @relation(fields: [agent_id], references: [id])
    kyc_status     ApprovalStatus @default(PENDING)
    pan_number     String
    pan_image      String
    aadhar_number  String
    aadhar_image   String
    bank_name      String
    account_number String
    branch_name    String
    ifsc_code      String
    upi_id         String?
    qr_code        String?
    created_at     DateTime       @default(now())
    updated_at     DateTime       @updatedAt

    @@index([pan_number, aadhar_number, bank_name, branch_name, ifsc_code, upi_id])
    @@map("tbl_agent_kyc")
}

model OTP {
    id             String    @id @default(uuid())
    credential     String    @unique
    otp            String
    limit          Int       @default(0)
    is_email       Boolean   @default(true)
    restrictedTime DateTime?
    created_at     DateTime  @default(now())
    expires_at     DateTime
    updated_at     DateTime  @updatedAt()

    @@index([credential])
    @@map("tbl_otp")
}

model InvalidatedToken {
    id         String   @id @default(uuid())
    token      String
    expires_at DateTime
    user_id    BigInt
    user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

    @@index([user_id])
    @@map("tbl_invalidated_tokens")
}

model UserFCMToken {
    id         BigInt   @id @default(autoincrement()) @db.BigInt
    user_id    BigInt
    user       User     @relation(fields: [user_id], references: [id])
    token      String
    created_at DateTime @default(now())
    updated_at DateTime @updatedAt

    @@map("tbl_user_fcm_tokens")
}

model InAppNotifications {
    id         BigInt   @id @default(autoincrement()) @db.BigInt
    user_id    BigInt
    user       User     @relation(fields: [user_id], references: [id])
    type       String
    title      String
    desc       String
    image      String?
    is_read    Boolean  @default(false)
    metadata   Json?
    created_at DateTime @default(now())

    @@index([user_id, type, title, desc, is_read])
    @@map("tbl_in_app_notifications")
}

model PushNotification {
    id         BigInt   @id @default(autoincrement()) @db.BigInt
    title      String
    body       String
    url        String?
    type       String?
    images     String?
    created_at DateTime @default(now())
    updated_at DateTime @updatedAt

    @@index([id])
    @@map("tbl_push_notifications")
}

/**
 * ============================================================
 * ORGANIZATION
 * ==============================================================
 */

model Organization {
    id            BigInt                     @id @default(autoincrement())
    name          String
    gst_number    String?
    pan_number    String?
    contact_email String?
    contact_phone String?
    status        Status                     @default(ACTIVE)
    created_by    BigInt                     @unique
    createdByUser User                       @relation("OrgCreatedBy", fields: [created_by], references: [id])
    created_at    DateTime                   @default(now())
    updated_at    DateTime                   @updatedAt
    subscription  OrganizationSubscription[]
    agentSales    AgentSale[]
    users         OrganizationUser[]
    customers     Customer[]
    toDos         ToDo[]

    @@index([name, gst_number, pan_number, contact_email, contact_phone])
    @@map("tbl_organization")
}

/**
 * ============================================================
 * ORGANIZATION USER (PIVOT)
 * ==============================================================
 */

model OrganizationUser {
    id           BigInt       @id @default(autoincrement())
    org_id       BigInt
    organization Organization @relation(fields: [org_id], references: [id])
    user_id      BigInt
    user         User         @relation(fields: [user_id], references: [id])
    role_id      BigInt
    role         Role         @relation(fields: [role_id], references: [id])
    status       Status       @default(ACTIVE)
    is_owner     Boolean      @default(false)
    created_at   DateTime     @default(now())
    updated_at   DateTime     @updatedAt

    @@unique([org_id, user_id])
    @@index([org_id, user_id, role_id, status])
    @@map("tbl_organization_user")
}

/**
 * ============================================================
 * CUSTOMER
 * ==============================================================
 */

model Customer {
    id             BigInt       @id @default(autoincrement())
    org_id         BigInt
    organization   Organization @relation(fields: [org_id], references: [id])
    created_by     BigInt
    createdByUser  User         @relation("CustomerCreatedBy", fields: [created_by], references: [id])
    first_name     String?
    last_name      String?
    email          String?
    phone          String?
    image          String?
    aadhaar_number String?
    pan_number     String?
    address        String?
    created_at     DateTime     @default(now())
    updated_at     DateTime     @updatedAt
    agentSales     AgentSale[]
    meetings       Meeting[]

    @@index([first_name, last_name, email, phone, aadhaar_number, pan_number])
    @@map("tbl_customer")
}

/**
 * ============================================================
 * PRODUCT TYPE
 * ==============================================================
 */

model Products {
    id         BigInt          @id @default(autoincrement())
    name       String          @unique
    slug       String
    status     Status          @default(ACTIVE)
    created_at DateTime        @default(now())
    updated_at DateTime        @updatedAt
    entities   ProductEntity[]

    @@index([name, status])
    @@map("tbl_products")
}

/**
 * ============================================================
 * PRODUCT ENTITY
 * ==============================================================
 */

model ProductEntity {
    id                   BigInt               @id @default(autoincrement())
    name                 String
    slug                 String               @unique
    product_id           BigInt
    products             Products             @relation(fields: [product_id], references: [id])
    status               Status               @default(ACTIVE)
    created_at           DateTime             @default(now())
    updated_at           DateTime             @updatedAt
    agentSales           AgentSale[]
    agentProductEntities AgentProductEntity[]

    @@index([name, slug, product_id, status])
    @@map("tbl_product_entity")
}

/**
 * ============================================================
 * AGENT PRODUCT ENTITY (PIVOT)
 * ==============================================================
 */

model AgentProductEntity {
    id                BigInt        @id @default(autoincrement())
    agent_id          BigInt
    agent             User          @relation(fields: [agent_id], references: [id])
    product_entity_id BigInt
    productEntity     ProductEntity @relation(fields: [product_entity_id], references: [id])
    created_at        DateTime      @default(now())
    updated_at        DateTime      @updatedAt

    @@unique([agent_id, product_entity_id])
    @@index([agent_id, product_entity_id])
    @@map("tbl_agent_product_entity")
}

/**
 * ============================================================
 * PRODUCT DETAILS TABLES
 * ==============================================================
 */

model AgentSale {
    id                BigInt                   @id @default(autoincrement())
    org_id            BigInt?
    organization      Organization?            @relation(fields: [org_id], references: [id])
    agent_id          BigInt
    agent             User                     @relation(fields: [agent_id], references: [id])
    customer_id       BigInt
    customer          Customer                 @relation(fields: [customer_id], references: [id])
    product_entity_id BigInt
    productEntity     ProductEntity            @relation(fields: [product_entity_id], references: [id])
    sale_date         DateTime                 @default(now())
    status            Status                   @default(ACTIVE)
    created_at        DateTime                 @default(now())
    updated_at        DateTime                 @updatedAt
    lifeInsurance     ProductLifeInsurance?
    medicalInsurance  ProductMedicalInsurance?
    mutualFund        ProductMutualFund?
    realEstate        ProductRealEstate?

    @@index([agent_id, customer_id, product_entity_id, sale_date, status])
    @@map("tbl_agent_sale")
}

model ProductLifeInsurance {
    id                BigInt             @id @default(autoincrement())
    sale_id           BigInt             @unique
    sale              AgentSale          @relation(fields: [sale_id], references: [id])
    policy_number     String?
    plan_name         String?
    policy_type       String?
    sum_assured       Float?
    premium_amount    Float?
    premium_frequency SubscriptionCycle? @default(MONTHLY)
    policy_term       Int? // years
    payment_term      Int?
    issue_date        DateTime?
    start_date        DateTime?
    end_date          DateTime?
    nominee_name      String?
    nominee_relation  String?
    policy_status     Status             @default(ACTIVE)
    notes             String?
    created_at        DateTime           @default(now())
    updated_at        DateTime           @updatedAt

    @@index([policy_number, plan_name, policy_type, policy_status])
    @@map("tbl_product_life_insurance")
}

model ProductMedicalInsurance {
    id                   BigInt    @id @default(autoincrement())
    sale_id              BigInt    @unique
    sale                 AgentSale @relation(fields: [sale_id], references: [id])
    policy_number        String?
    plan_name            String?
    coverage_amount      Float?
    premium_amount       Float?
    policy_type          String? // Individual / Family Floater
    insured_members      Json? // [{name, age, relation}]
    pre_existing_disease String?
    waiting_period       Int? // months
    issue_date           DateTime?
    start_date           DateTime?
    end_date             DateTime?
    policy_status        Status    @default(ACTIVE)
    notes                String?
    created_at           DateTime  @default(now())
    updated_at           DateTime  @updatedAt

    @@index([policy_number, plan_name, policy_type, policy_status])
    @@map("tbl_product_medical_insurance")
}

model ProductMutualFund {
    id                BigInt    @id @default(autoincrement())
    sale_id           BigInt    @unique
    sale              AgentSale @relation(fields: [sale_id], references: [id])
    folio_number      String?
    scheme_name       String?
    fund_house        String?
    investment_type   String? // SIP / LUMPSUM
    investment_amount Float?
    nav               Float?
    units             Float?
    sip_start_date    DateTime?
    sip_end_date      DateTime?
    risk_profile      String?
    notes             String?
    created_at        DateTime  @default(now())
    updated_at        DateTime  @updatedAt

    @@index([folio_number, scheme_name, investment_type])
    @@map("tbl_product_mutual_fund")
}

model ProductRealEstate {
    id BigInt @id @default(autoincrement())

    sale_id         BigInt    @unique
    sale            AgentSale @relation(fields: [sale_id], references: [id])
    property_type   String? // Flat / Land / Commercial
    property_name   String?
    location        String?
    area_sqft       Float?
    property_value  Float?
    booking_amount  Float?
    builder_name    String?
    agreement_date  DateTime?
    possession_date DateTime?
    ownership_type  String?
    notes           String?
    created_at      DateTime  @default(now())
    updated_at      DateTime  @updatedAt

    @@index([property_type, location, property_name, builder_name, ownership_type])
    @@map("tbl_product_real_estate")
}

/**
 * ============================================================
 * RAZORPAY SUBSCRIPTION
 * ==============================================================
 */
model SubscriptionPlan {
    id                       BigInt                     @id @default(autoincrement())
    code                     String                     @unique
    name                     String
    description              String?
    price                    Int
    currency_id              BigInt
    currency                 Currency                   @relation(fields: [currency_id], references: [id])
    billing_cycle            SubscriptionCycle
    max_agents               Int?
    rzp_plan_id              String?                    @unique
    is_active                Boolean                    @default(true)
    created_at               DateTime                   @default(now())
    updated_at               DateTime                   @updatedAt
    subscriptions            OrganizationSubscription[]
    subscriptionPlanFeatures SubscriptionPlanFeature[]

    @@index([code, billing_cycle, is_active])
    @@map("tbl_subscription_plan")
}

model OrganizationSubscription {
    id                      BigInt                 @id @unique @default(autoincrement())
    org_id                  BigInt
    organization            Organization           @relation(fields: [org_id], references: [id])
    plan_id                 BigInt
    plan                    SubscriptionPlan       @relation(fields: [plan_id], references: [id])
    status                  SubscriptionStatus
    source                  SubscriptionSource     @default(RAZORPAY)
    start_at                DateTime
    end_at                  DateTime?
    auto_renew              Boolean                @default(true)
    cancelled_at            DateTime?
    rzp_subscription_id     String?                @unique
    reconciliation_attempts Int                    @default(0)
    last_reconciled_at      DateTime?
    created_at              DateTime               @default(now())
    updated_at              DateTime               @updatedAt
    razorpaySubscriptions   RazorpaySubscription[]

    @@unique([org_id, rzp_subscription_id])
    @@index([org_id, plan_id, status])
    @@map("tbl_org_subscription")
}

model SubscriptionFeature {
    id          BigInt                    @id @default(autoincrement())
    key         String                    @unique
    name        String
    description String?
    plans       SubscriptionPlanFeature[]

    @@map("tbl_subscription_feature")
}

model SubscriptionPlanFeature {
    id         BigInt              @id @default(autoincrement())
    plan_id    BigInt
    plan       SubscriptionPlan    @relation(fields: [plan_id], references: [id])
    feature_id BigInt
    feature    SubscriptionFeature @relation(fields: [feature_id], references: [id])

    @@unique([plan_id, feature_id])
    @@map("tbl_subscription_plan_feature")
}

model RazorpaySubscription {
    id                  BigInt                   @id @default(autoincrement())
    org_subscription_id BigInt
    org_subscription    OrganizationSubscription @relation(fields: [org_subscription_id], references: [id])
    rzp_subscription_id String                   @unique
    rzp_plan_id         String
    status              String
    current_cycle       Int?
    total_count         Int?
    start_at            DateTime?
    end_at              DateTime?
    created_at          DateTime                 @default(now())
    updated_at          DateTime                 @updatedAt
    events              RazorpayEvent[]

    @@map("tbl_razorpay_subscription")
}

model RazorpayEvent {
    id                    BigInt                @id @default(autoincrement())
    razorpay_entity_id    String
    entity_type           RazorpayEntityType    @default(SUBSCRIPTION)
    event_type            String
    payload               Json
    created_at            DateTime              @default(now())
    razorpay_subscription RazorpaySubscription? @relation(fields: [subscription_id], references: [id])
    subscription_id       BigInt?

    @@index([razorpay_entity_id, event_type, entity_type])
    @@map("tbl_razorpay_event")
}

model Meeting {
    id              BigInt        @id @default(autoincrement())
    agent_id        BigInt
    agent           User          @relation(fields: [agent_id], references: [id])
    customer_id     BigInt?
    customer        Customer?     @relation(fields: [customer_id], references: [id])
    title           String
    description     String?
    meeting_type    MeetingType   @default(REMINDER)
    start_time      DateTime
    end_time        DateTime?
    status          MeetingStatus @default(SCHEDULED)
    is_completed    Boolean       @default(false)
    completed_at    DateTime?
    mom             String?
    reminder_before Int?
    reminder_sent   Boolean       @default(false)
    created_at      DateTime      @default(now())
    updated_at      DateTime      @updatedAt

    @@index([agent_id, start_time, status, reminder_sent])
    @@map("tbl_meetings")
}

model ToDo {
    id           BigInt        @id @default(autoincrement())
    org_id       BigInt?
    organization Organization? @relation(fields: [org_id], references: [id])
    agent_id     BigInt
    agent        User          @relation(fields: [agent_id], references: [id])
    title        String
    description  String?
    due_date     DateTime?
    priority     Priority      @default(MEDIUM)
    is_completed Boolean       @default(false)
    completed_at DateTime?
    created_at   DateTime      @default(now())
    updated_at   DateTime      @updatedAt

    @@index([org_id, agent_id, is_completed, due_date])
    @@map("tbl_todo")
}
